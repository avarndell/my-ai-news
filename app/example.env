# PostgreSQL (used by Docker and the app)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ainews
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy connection string (constructed from the above)
DATABASE_URL=postgresql://ainews:ainews_secret@localhost:5432/ainews

# Webshare proxy for YouTube transcript fetching (optional — leave blank to skip)
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# OpenAI — used by the digest agent
OPENAI_API_KEY=""
OPENAI_DIGEST_MODEL=gpt-5.2
